# Copy this file to .env and replace every change_me or replace_me value before starting services.

# OpenClaw gateway.
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_GATEWAY_TOKEN=replace_me_with_a_long_random_gateway_token
TELEGRAM_BOT_TOKEN=replace_me_with_botfather_token
OPENCLAW_TZ=Europe/Chisinau
OPENCLAW_TIMEZONE=Europe/Chisinau
LIFEOS_API_BASE_URL=http://lifeos-api:8080
LIFEOS_API_TOKEN=replace_me_with_a_long_random_lifeos_api_token
LIFEOS_API_TIMEOUT_MS=10000

# Telegram access control notes:
# Operators must fill real Telegram user, group, and topic IDs in OpenClaw config
# at openclaw/config/openclaw.json after bootstrap creates the mounted config path.
# Example ID shapes only:
# - user ID: 123456789
# - group/supergroup ID: -1001234567890
# - forum topic ID: 42
# Keep webhookUrl and webhookSecret unset to use OpenClaw Telegram long polling.
TELEGRAM_ALLOWED_USER_ID=replace_me_with_owner_user_id
TELEGRAM_ALLOWED_GROUP_ID=replace_me_with_private_supergroup_id
TELEGRAM_ALLOWED_GROUP_TITLE=LifeOS
TELEGRAM_TOPIC_DAILY_ID=replace_me_with_daily_topic_id
TELEGRAM_TOPIC_SPORT_ID=replace_me_with_sport_topic_id
TELEGRAM_TOPIC_BUSINESS_ID=replace_me_with_business_topic_id
TELEGRAM_TOPIC_FINANCE_ID=replace_me_with_finance_topic_id
TELEGRAM_TOPIC_FOOD_ID=replace_me_with_food_topic_id
TELEGRAM_TOPIC_REVIEW_ID=replace_me_with_review_topic_id
TELEGRAM_TOPIC_ADMIN_ID=replace_me_with_admin_topic_id

# LifeOS API.
LIFEOS_API_PORT=8080
LIFEOS_API_NODE_ENV=production

# Database. Keep DATABASE_URL in sync with these values.
POSTGRES_DB=lifeos
POSTGRES_USER=lifeos
POSTGRES_PASSWORD=change_me_postgres_password
DATABASE_URL=postgresql://lifeos:change_me_postgres_password@lifeos-db:5432/lifeos

# API-owned commands run inside the services/lifeos-api image.
LIFEOS_MIGRATE_COMMAND="alembic upgrade head"
LIFEOS_SEED_COMMAND="python -m lifeos_api.seed"

# Backups.
LIFEOS_BACKUP_RETENTION_DAYS=14
LIFEOS_BACKUP_INTERVAL_SECONDS=86400
